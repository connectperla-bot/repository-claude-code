# Copia questo file in printify.local.env e inserisci le tue credenziali reali.
# NON versionare / NON condividere printify.local.env.
# NON inserire mai queste chiavi nel file .bat.

SHOPIFY_WEBHOOK_SECRET=
PRINTIFY_API_KEY=
PRINTIFY_SHOP_ID=

# Mappatura per tipo di prodotto (studio di personalizzazione).
# blueprint/provider sono gia' compilati con i dati reali del catalogo Printify.
# *_VARIANT_ID va scelto da te in base a taglia/colore che vendi davvero:
# GET https://api.printify.com/v1/catalog/blueprints/<blueprint>/print_providers/<provider>/variants.json
COLLARE_BLUEPRINT_ID=784
COLLARE_PROVIDER_ID=93
COLLARE_VARIANT_ID=

BANDANA_BLUEPRINT_ID=562
BANDANA_PROVIDER_ID=70
BANDANA_VARIANT_ID=

MEDAGLIETTA_BLUEPRINT_ID=566
MEDAGLIETTA_PROVIDER_ID=70
MEDAGLIETTA_VARIANT_ID=

CIOTOLA_BLUEPRINT_ID=570
CIOTOLA_PROVIDER_ID=70
CIOTOLA_VARIANT_ID=

CUCCIA_BLUEPRINT_ID=419
CUCCIA_PROVIDER_ID=10
CUCCIA_VARIANT_ID=

TAPPETINO_BLUEPRINT_ID=855
TAPPETINO_PROVIDER_ID=70
TAPPETINO_VARIANT_ID=

GUINZAGLIO_BLUEPRINT_ID=2791
GUINZAGLIO_PROVIDER_ID=80
GUINZAGLIO_VARIANT_ID=

# Assistente AI (scripts/perla-assistant-bot.js) - chiave gratuita su https://aistudio.google.com/apikey
GEMINI_API_KEY=
ALLOWED_ORIGIN=*

PORT=3000
MAX_UPLOAD_MB=10
